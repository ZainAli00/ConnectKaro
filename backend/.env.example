# --- Server ---
PORT=4000
NODE_ENV=development

# --- Database ---
# Local docker-compose default shown; swap for a hosted Postgres URL (Neon/Supabase/Railway) if you don't run Docker locally.
DATABASE_URL="postgresql://connectkro:connectkro@localhost:5432/connectkro"

# --- CORS ---
# Comma-separated list of allowed frontend origins.
CORS_ALLOWED_ORIGINS="http://localhost:5173"

# --- Auth ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET="replace-with-a-long-random-string"
JWT_ACCESS_EXPIRES_IN="1h"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-string"
JWT_REFRESH_EXPIRES_IN="30d"

# --- Seed admin (used only by prisma/seed.js) ---
SEED_ADMIN_EMAIL="admin@connectkro.pk"
SEED_ADMIN_PASSWORD="change-me-after-first-login"
SEED_ADMIN_NAME="connectkro Admin"

# --- eSIM provider ---
# "mock" (default, no real credentials needed) or "live" once real supplier auth wiring is confirmed.
ESIM_PROVIDER="mock"
ESIM_SUPPLIER_BASE_URL=""
ESIM_SUPPLIER_API_KEY=""
ESIM_SUPPLIER_ACCESS_TOKEN=""

# --- Usage cache ---
USAGE_CACHE_TTL_SECONDS=300
